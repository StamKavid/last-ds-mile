{
  "description": "Last DS Mile safe set — session safety posture, untrusted-input scanning, session-state persistence, and learnings capture. Warn-don't-block by default; see AUDIT.md.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ds-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/session_start.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ds-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/scan_untrusted_input.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ds-python.sh\" \"${CLAUDE_PLUGIN_ROOT}/hooks/scan_untrusted_input.py\""
          }
        ]
      }
    ]
  }
}
