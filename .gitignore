__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/
.gstack/

# .last-ds-mile/ is where the plugin writes each stage's output in a user's
# project. Keep the narrative evidence a run produces (stages/*.md), never the
# raw data or heavy artifacts that live alongside it.
.last-ds-mile/dev.csv
.last-ds-mile/preds.csv

# Raw datasets pulled down to run a pipeline locally (Kaggle CSVs etc.) — this
# repo never commits source data, which also keeps redistribution of
# third-party dataset licenses out of scope.
data/

# Reference runs under benchmarks/: keep the narrative evidence a run produces
# (stage markdown, LEDGER.md, contract.json/comparison.json, figures, the
# scripts that generated a run) — never the raw Kaggle CSVs or the heavy
# model/AutoGluon artifacts a run leaves behind alongside it.
benchmarks/*/*.csv
benchmarks/*/*.txt
!benchmarks/**/requirements-lock.txt
benchmarks/**/auto/
benchmarks/**/held/
benchmarks/**/*.pkl
benchmarks/**/*.ubj
benchmarks/**/*.joblib
benchmarks/**/dev.csv
benchmarks/**/preds.csv
benchmarks/**/oof_predictions.csv
benchmarks/**/seal_state.json
benchmarks/**/catboost_info/
